#include "xbee.h"
#include "usart.h"


extern UART_HandleTypeDef huart1;

static uint8_t rx_byte;
#define RX_BUFFER_SIZE 64
static uint8_t rx_buffer[RX_BUFFER_SIZE];
static uint8_t rx_index = 0;
static uint8_t temp_byte;
void XBee_Reset(void)
{
    HAL_GPIO_WritePin(XBEE_RESET_PORT, XBEE_RESET_PIN, GPIO_PIN_RESET);
    HAL_Delay(10);
    HAL_GPIO_WritePin(XBEE_RESET_PORT, XBEE_RESET_PIN, GPIO_PIN_SET);
    HAL_Delay(200); // attendre boot XBee
    HAL_UART_Receive_IT(&huart1, &temp_byte, 1);
}

void XBee_Send(uint8_t *data, uint16_t len)
{
    HAL_UART_Transmit(XBEE_UART, data, len, HAL_MAX_DELAY);
}

void XBee_StartReceive(void)
{
    HAL_UART_Receive_IT(XBEE_UART, &rx_byte, 1);
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART1)
    {
        // 1. Stocker l'octet reçu dans le buffer
        if (rx_index < RX_BUFFER_SIZE - 1) {
            rx_buffer[rx_index++] = temp_byte;
        }

        // 2. Optionnel : Détecter la fin d'un message (ex: un retour à la ligne '\n')
        if (temp_byte == '\n') {
            // Ici, tu peux lever un drapeau (flag) pour dire au main()
            // qu'un message complet est arrivé
            rx_buffer[rx_index] = '\0'; // Fin de chaîne
            rx_index = 0; // Prêt pour le prochain message
        }

        // 3. RELANCER l'écoute (Crucial !)
        HAL_UART_Receive_IT(&huart1, &temp_byte, 1);
    }
}
