#include "ads1015.h"
static uint16_t adc_value_int;
static uint8_t i2c_rx_buffer[2];
static uint8_t i2c_tx_buffer[2];

#define ADS1015_REG_CONFIG 0x01
#define ADS1015_REG_CONV   0x00

int ADS1015_Test_Connection() {
    uint8_t config_reg_addr = ADS1015_REG_CONFIG;
    uint8_t data_rx[2];

    // 1. On pointe vers le registre de configuration
    // 2. On lit 2 octets pour voir la config par défaut (0x8583)
    if (HAL_I2C_Master_Transmit(&hi2c1, ADC_ADDRESS << 1, &config_reg_addr, 1, 100) != HAL_OK) {
        return -1; // Problème de bus ou adresse incorrecte
    }

    if (HAL_I2C_Master_Receive(&hi2c1, ADC_ADDRESS << 1, data_rx, 2, 100) != HAL_OK) {
        return -1;
    }

    // Si on lit 0x8583, la communication est parfaite.
    uint16_t config_val = (data_rx[0] << 8) | data_rx[1];
    return (config_val == 0x8583) ? 0 : -2;
}

