eXBeeRF_Status_t XBeeRF_getStatus(void){
	// return XBee900HP status
	return RF_Status; // info about Xbee connection (in range or out of range)
}

void XBeeRF_ChangeStatus(eXBeeRF_Status_t STATE){
	if (STATE == IN_RANGE){
		last_receive = HAL_GetTick();
	}
	RF_Status = STATE;
}


void RF_Extract(uint8_t msgStartPointer, uint8_t* dmaList){
	sCANMessage_t messageToSend;
	switch(dmaList[msgStartPointer + 4]){
		case 0x01:
			messageToSend = RF_DecodeStdData(msgStartPointer, dmaList);
			break;
		default:
			return;
	}

	if(assertMessageValidity(&messageToSend))
		sendReceivedMsg(&messageToSend);


}

// This only works in the case of fixed 20 bytes length frame
sCANMessage_t RF_DecodeStdData(uint8_t msgStartPointer, uint8_t* dmaList){
	static sCANMessage_t msgToSend;
    uint16_t msgLength = (dmaList[msgStartPointer + 1] << 8) | dmaList[msgStartPointer + 2];
	uint8_t dataLen = msgLength - 10;
	uint8_t idPointer = dmaList[msgStartPointer];
	for(int i = msgStartPointer + 13; i < msgStartPointer + XBEE_RF_UART_DMA_SIZE - 1; ++i ){
		if(dmaList[i] != 0x00){
			idPointer = i;
			break;
		}
	}

	uint8_t payloadLen = 0;
	for(int i = idPointer + 1; i < msgStartPointer + 19;++i){
		msgToSend.data[i - idPointer - 1] = dmaList[i];
		++payloadLen;
	}
	msgToSend.valid = 0;
	msgToSend.length = payloadLen;
	msgToSend.address = dmaList[idPointer];

	return msgToSend;
}
