static uint16_t adc_value_int;
static uint8_t i2c_rx_buffer[2];
static uint8_t i2c_tx_buffer[2];

#define ADS1015_REG_CONFIG 0x01
#define ADS1015_REG_CONV   0x00

#define ADS1015_ADDR 0x90
#define REG_CONV     0x00
#define REG_CONFIG   0x01

extern I2C_HandleTypeDef hi2c1; // Assurez-vous que l'I2C est initialisé

void Read_ADS1015_SingleShot(void) {
    uint8_t config[3];
    uint8_t data[2];
    int16_t val;

    // 1. Configuration : AIN0, +/- 4.096V, Mode Single-shot
    // Bit 15 : OS (1 = Start conversion)
    // Bits 14-12 : MUX (100 = AIN0 vs GND)
    // Bits 11-9 : PGA (001 = +/- 4.096V)
    // Bit 8 : MODE (1 = Single-shot)
    config[0] = REG_CONFIG;
    config[1] = 0xC3; // 1100 0011
    config[2] = 0x83; // 1000 0011 (1600 SPS)

    HAL_I2C_Master_Transmit(&hi2c1, ADS1015_ADDR, config, 3, HAL_MAX_DELAY);

    // 2. Attendre la fin de conversion (optionnel : vérifier le bit MSB du registre config)
    HAL_Delay(10);

    // 3. Lire le registre de conversion
    uint8_t reg = REG_CONV;
    HAL_I2C_Master_Transmit(&hi2c1, ADS1015_ADDR, &reg, 1, HAL_MAX_DELAY);
    HAL_I2C_Master_Receive(&hi2c1, ADS1015_ADDR, data, 2, HAL_MAX_DELAY);

    // 4. Formater les données (L'ADS1015 a 12 bits, alignés à gauche sur 16 bits)
    val = (data[0] << 8) | data[1];
    val = val >> 4; // Décalage pour obtenir la valeur sur 12 bits

    // Conversion en tension (si PGA = +/- 4.096V, 1 bit = 2mV)
    float voltage = val * 0.002f;
}

