void RF_Transmission_Init(void){
    // Make sure nRst is HIGH so the reset is FALSE
    HAL_GPIO_WritePin(XBEE_N_RESET_GPIO_Port,XBEE_N_RESET_Pin,GPIO_PIN_SET);
    // Init the USART interface calling usart.c fonction
    MX_USART1_UART_Init();
}

